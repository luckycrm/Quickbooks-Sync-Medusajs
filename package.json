{
  "name": "quickbooks-sync-medusajs",
  "version": "1.0.0",
  "description": "Synchronize Medusa.js orders , customers and products with QuickBooks Online.",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-other",
    "medusa-plugin",
    "medusa-v2"
  ],
  "scripts": {
    "build": "npx -y node@24 ./scripts/build-plugin.cjs",
    "dev": "npx -y node@24 ./scripts/develop-plugin.cjs",
    "build:node24": "npx -y node@24 ./scripts/build-plugin.cjs",
    "dev:node24": "npx -y node@24 ./scripts/develop-plugin.cjs",
    "publish:node24": "npx -y node@24 ./scripts/publish-plugin.cjs",
    "prepublishOnly": "npx -y node@24 ./scripts/build-plugin.cjs"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/icons": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@medusajs/test-utils": "2.13.1",
    "@medusajs/ui": "4.0.25",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/icons": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@medusajs/test-utils": "2.13.1",
    "@medusajs/ui": "4.0.25"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.4.0",
  "dependencies": {
    "intuit-oauth": "^4.2.2",
    "node-quickbooks": "^2.0.48",
    "sharp": "^0.34.5"
  }
}